{
  "name": "chapaev-server",
  "version": "0.1.0",
  "private": true,
  "description": "Chapayev game server using Phalanx Engine",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "rebuild:native": "pnpm rebuild better-sqlite3",
    "dev": "tsx src/main.ts",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/scripts/migrate.ts",
    "bot:setup": "tsx src/scripts/botSetup.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.42.0",
    "@phalanx-engine/server": "^0.1.4",
    "pino": "^10.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaeton-forge/phalanx-games.git",
    "directory": "chapaev/server"
  },
  "bugs": "https://github.com/phaeton-forge/phalanx-games/issues",
  "homepage": "https://github.com/phaeton-forge/phalanx-games/tree/main/chapaev/server#readme",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  }
}
