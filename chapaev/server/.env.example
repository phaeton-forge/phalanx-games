# Server environment variables

PORT=3000
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://127.0.0.1:5174

# Database
DATABASE_PATH=./data/chapaev.db

# Telegram Bot
# Set to false to disable the bot subsystem entirely
BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
# Must be at least 16 characters — generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=TODO_generate_a_secret
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Full public URL where this server is reachable (used to register the webhook)
PUBLIC_URL=https://chapaev-backend.onrender.com
# Your Mini App URL — must be the direct HTTPS URL registered in @BotFather
# (used as the web_app button URL and to register the Telegram webhook)
WEB_APP_URL=https://chapaev.onrender.com
BOT_USERNAME=YourBotUsername
FEEDBACK_CHAT_ID=

