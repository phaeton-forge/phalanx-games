{
  "name": "arena-shooter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --mode development",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "cap:run": "cap run android",
    "android": "pnpm build && cap sync android",
    "android:open": "pnpm build && cap sync android && cap open android",
    "android:run": "pnpm build && cap sync android && cap run android",
    "android:dev": "CAPACITOR_DEV=true cap sync android && CAPACITOR_DEV=true cap run android",
    "android:dev:live": "npx concurrently --kill-others \"pnpm dev\" \"pnpm android:dev\""
  },
  "dependencies": {
    "@babylonjs/core": "8.53.0",
    "@babylonjs/gui": "8.53.0",
    "@babylonjs/materials": "8.53.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@phalanx-engine/ecs": "^0.1.4",
    "@phalanx-engine/math": "^0.1.4",
    "@phalanx-engine/physics": "^0.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phaeton-forge/phalanx-games.git",
    "directory": "arena-shooter"
  },
  "bugs": "https://github.com/phaeton-forge/phalanx-games/issues",
  "homepage": "https://github.com/phaeton-forge/phalanx-games/tree/main/arena-shooter#readme",
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
